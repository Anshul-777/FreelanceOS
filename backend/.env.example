# FreelanceOS Backend — Environment Variables
# Copy this to .env and customize as needed

# App
APP_NAME=FreelanceOS
DEBUG=true

# Database (SQLite — change to PostgreSQL URL for production)
DATABASE_URL=sqlite:///./freelanceos.db

# JWT Secret — CHANGE THIS IN PRODUCTION to a random 64-char string
SECRET_KEY=freelanceos-super-secret-key-change-in-production-2024
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=43200

# CORS — Frontend origin
FRONTEND_URL=http://localhost:5173

# Demo user credentials (auto-created on first run)
DEMO_EMAIL=demo@freelanceos.com
DEMO_PASSWORD=demo123
DEMO_NAME=Alex Johnson
DEMO_COMPANY=Alex Johnson Design & Dev
DEMO_HOURLY_RATE=95.0
DEMO_CURRENCY=USD
